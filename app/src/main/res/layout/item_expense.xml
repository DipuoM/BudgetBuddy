<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="4dp"
    android:backgroundTint="@color/surface"
    app:strokeColor="@color/pink_light"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/ivExpenseImage"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:visibility="gone"
            android:scaleType="centerCrop"
            android:layout_marginEnd="16dp"
            android:background="@drawable/image_placeholder_pink"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvExpenseTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Title"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/pink_dark"
                android:fontFamily="sans-serif-black"/>

            <TextView
                android:id="@+id/tvExpenseAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="R0"
                android:textSize="14sp"
                android:textColor="@color/pink_primary"
                android:layout_marginTop="4dp"
                android:fontFamily="sans-serif-black"/>

            <TextView
                android:id="@+id/tvExpenseDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2025-01-01"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp"
                android:fontFamily="sans-serif-black"/>

            <TextView
                android:id="@+id/tvExpenseCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Category"
                android:textSize="12sp"
                android:textColor="@color/pink_light"
                android:layout_marginTop="2dp"
                android:fontFamily="sans-serif-black"/>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>